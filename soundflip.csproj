<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- WinExe: no console window is ever created (no flash on double-click, none
         at login). CLI verbs attach to the parent terminal's console instead. -->
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows10.0.22621.0</TargetFramework>
    <SupportedOSPlatformVersion>10.0.19041.0</SupportedOSPlatformVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <AssemblyName>soundflip</AssemblyName>
    <RootNamespace>SoundFlip</RootNamespace>
    <Product>SoundFlip</Product>
    <Version>1.3.5</Version>
    <Description>Minimal Windows audio device switcher with tray-based output and input toggling.</Description>
    <Company>Kirill Fedorov</Company>
    <Copyright>© 2026 Kirill Fedorov</Copyright>
    <!-- Multi-size file icon for the exe (Explorer/taskbar). Generated from the
         MIT-licensed Fluent UI System Icons "Speaker 2" glyph; the tray icon in
         UI.cs (TrayArt.SpeakerPath) uses the same path data. -->
    <ApplicationIcon>app.ico</ApplicationIcon>
    <InvariantGlobalization>true</InvariantGlobalization>
    <!-- Single self-contained .exe, no install / no .NET runtime needed on the machine -->
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="AudioSwitcher.AudioApi" Version="4.0.0-alpha5" />
    <PackageReference Include="AudioSwitcher.AudioApi.CoreAudio" Version="4.0.0-alpha5" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="soundflip.Tests/**/*.cs" />
  </ItemGroup>

  <!-- Surfaced in the About dialog via AssemblyMetadataAttribute. -->
  <ItemGroup>
    <AssemblyMetadata Include="HomepageUrl" Value="https://github.com/geronimonzy/soundflip" />
    <AssemblyMetadata Include="SupportUrl" Value="https://github.com/geronimonzy/soundflip/issues" />
  </ItemGroup>

  <!-- The package targets .NET Framework; it works fine on net8-windows, so
       silence the cross-targeting restore warning. -->
  <PropertyGroup>
    <NoWarn>$(NoWarn);NU1701</NoWarn>
  </PropertyGroup>

</Project>
